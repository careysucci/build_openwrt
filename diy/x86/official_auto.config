CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

#
# Image Options
#
CONFIG_TARGET_KERNEL_PARTSIZE=256
CONFIG_TARGET_ROOTFS_PARTSIZE=500

#
# Root filesystem images
#
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_EXT4_BLOCKSIZE_4K=y
CONFIG_TARGET_EXT4_BLOCKSIZE=4096
CONFIG_TARGET_EXT4_JOURNAL=y
CONFIG_TARGET_UBIFS_FREE_SPACE_FIXUP=y
CONFIG_GRUB_IMAGES=y
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_VDI_IMAGES=y
CONFIG_TARGET_ROOTFS_TARGZ=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_DROPBEAR_SCP=y

#
# Translations
#
CONFIG_LUCI_LANG_zh_Hans=y

#
# ===== Kernel Optimization =====
#
CONFIG_KERNEL_SMP=y
CONFIG_KERNEL_RPS=y
CONFIG_KERNEL_XPS=y
CONFIG_KERNEL_NETDEVICES_MULTIQUEUE=y

#
# ===== TurboACC / Shortcut-FE (LEDE-specific acceleration) =====
#
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_shortcut-fe=y
CONFIG_PACKAGE_kmod-shortcut-fe=y

#
# ===== Flow Offload (can coexist with SFE) =====
#
CONFIG_PACKAGE_kmod-nft-flow=y
CONFIG_PACKAGE_kmod-nft-flow-offload=y
CONFIG_PACKAGE_kmod-nft-offload=y

#
# ===== IRQ Balancing =====
#
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_ethtool=y

#
# ===== Network Drivers =====
#
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-igb=y
CONFIG_PACKAGE_kmod-i40e=y
CONFIG_PACKAGE_kmod-ixgbe=y
CONFIG_PACKAGE_kmod-atlantic=y
CONFIG_PACKAGE_kmod-r8125=y

#
# ===== Virtio (VM/Proxmox Support) =====
#
CONFIG_PACKAGE_kmod-virtio=y
CONFIG_PACKAGE_kmod-virtio-net=y
CONFIG_PACKAGE_kmod-virtio-net-pci=y

#
# ===== Base Components =====
#
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_netperf=y
CONFIG_PACKAGE_htop=y

#
# ===== Default Packages =====
#
CONFIG_DEFAULT_libustream-mbedtls=n
CONFIG_DEFAULT_libustream-openssl=y

#
# ===== LuCI Web Interface =====
#
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Rust_Client=n
CONFIG_PACKAGE_luci-ssl=n
CONFIG_PACKAGE_luci-ssl-nginx=n
CONFIG_PACKAGE_luci-nginx=y

#
# ===== Firewall Configuration (LEDE uses traditional firewall) =====
#
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_firewall4=n

#
# ===== DNS Configuration =====
#
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcp=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y

#
# ===== Extended Packages =====
#
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-nikki=y
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-app-netspeedtest=y
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-app-minidlna=y
CONFIG_PACKAGE_luci-app-eqos=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_nano-full=y

#
# ===== Themes =====
#
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

#
# ===== Disable Unnecessary Apps =====
#
CONFIG_PACKAGE_luci-app-filetransfer=n
CONFIG_PACKAGE_luci-app-ssr-plus=n
CONFIG_PACKAGE_luci-app-vsftpd=n
CONFIG_PACKAGE_luci-app-ksmbd=n
CONFIG_PACKAGE_luci-app-bypass=n
CONFIG_PACKAGE_luci-app-bypass_INCLUDE_Shadowsocks_Libev_Client=n
CONFIG_PACKAGE_luci-app-bypass_INCLUDE_Shadowsocks_Libev_Server=n
CONFIG_PACKAGE_luci-app-bypass_INCLUDE_ShadowsocksR_Libev_Client=n
CONFIG_PACKAGE_luci-app-bypass_INCLUDE_ShadowsocksR_Libev_Server=n
CONFIG_PACKAGE_luci-app-bypass_INCLUDE_Simple_Obfs=n
CONFIG_PACKAGE_luci-app-bypass_INCLUDE_Xray=n
CONFIG_PACKAGE_luci-app-bypass_INCLUDE_Trojan=n
CONFIG_PACKAGE_luci-app-bypass_INCLUDE_Socks_Server=n


#
# ===== CRITICAL: Force disable iptables for kmod-nf-ipt on Linux 6.12+ =====
#
CONFIG_PACKAGE_kmod-nf-ipt=n
CONFIG_PACKAGE_kmod-nf-ipt6=n
CONFIG_PACKAGE_kmod-ipt-core=n
CONFIG_PACKAGE_kmod-iptables=n
CONFIG_PACKAGE_kmod-ip6tables=n
CONFIG_IP_NF_IPTABLES=n
CONFIG_IP6_NF_IPTABLES=n